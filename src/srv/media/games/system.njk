---
title: "Games: System"
---

{% include "media/navbar.njk" %}
{% include "games/navbar.njk" %}

<table class="plain">
  <thead>
    <tr>
      <th>Title</th>
      <th>Model</th>
    </tr>
  </thead>
  <tbody>
    {% for system in fetch.games.system
      | sort(attribute="title")
      | sort(attribute="system")
    %}
      <tr>
        <td class="title">
          {{ system.title }}
          {% if system.variation %}<span class="variation">({{ system.variation }})</span>{% endif %}
        </td>
        <td class="model">{{ system.model }}</td>
      </tr>
    {% endfor %}
  </tbody>
</table>

<style>{% include "style/media.css" %}</style>
<style>
  table.plain {
    .title {
      font-family: var(--serif);
    }

    .variation {
      font-family: var(--serif);
      color: oklch(from currentColor l c h / .6);
    }

    .model {
      font: .8em var(--mono);
      color: oklch(from currentColor l c h / .6);
    }
  }
</style>
