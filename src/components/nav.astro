---
interface Props {
  hier;
}

const { hier } = Astro.props;
---

<ul>{Object.values(hier).map((page) => (
  <li>
    <a href={page.link}>
      <span class="icon">
        <img class="idle" src=`https://www.apache.org/icons/${page.icon.idle}.png`/>
        <img class="peek" src=`https://www.apache.org/icons/${page.icon.peek}.png`/>
      </span>
      <span class="name">{page.name}{page.hier && "/"}</span>
    </a>
    {page.hier && <Astro.self hier={page.hier}/>}
  </li>
))}</ul>

<style>
  ul {
    background-color: light-dark(var(--oc-gray-2), var(--oc-gray-8));
    display: flex;
    flex-flow: row wrap;
    gap: .5em;
    list-style: none;
    margin: 0;
    padding: 0;

    ul,
    li {
      border: .5px solid light-dark(var(--oc-gray-5), var(--oc-gray-6));
      border-radius: .4em;
    }

    li {
      margin: 0;
      padding: 0;
      white-space: nowrap;

      &:hover {
        background-color: light-dark(var(--oc-cyan-8), var(--oc-cyan-4));
        transition: all .3s ease;

        > :not(ul) {
          color: light-dark(var(--oc-gray-2), var(--oc-gray-8));
        }
      }

      &:not(:hover) > ul {
        display: none;
      }

      a {
        align-items: center;
        display: inline-flex;
        flex-direction: row;
        gap: .5em;
        padding: .6em;

        & {
          color: inherit;
          text-decoration: none;
        }

        img {
          border-radius: 0;
          grid-column: 1;
          grid-row: 1;
          grid: 1;
          height: 22px;
          margin: 0;
          min-width: max-content;
        }

        .icon {
          margin: 0;
          display: grid;
          grid-template-columns: 1fr;
        }

        .idle, &:hover .peek {
          visibility: visible;
        }

        .peek, &:hover .idle {
          visibility: hidden;
        }
      }
    }

    li ul {
      box-shadow: 0 2px 3px light-dark(var(--oc-gray-5), var(--oc-black));
      gap: .25em;
      flex-direction: column;
      padding: .5em;
      position: absolute;
      z-index: 1;

      li {
        border: none;
      }

      a {
        padding: .4em;
      }
    }

  }
</style>
